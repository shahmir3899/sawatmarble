// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  owner
  staff
  accountant
}

enum ItemUnit {
  sqft
  piece
}

enum StockDirection {
  IN
  OUT
}

enum QuotationStatus {
  draft
  sent
  accepted
  expired
}

enum ChallanStatus {
  draft
  dispatched
  delivered
}

// Mirrors auth.users (Supabase Auth) 1:1. Row is created automatically by a
// trigger on auth.users insert (see migration SQL) with role defaulting to
// staff; only an owner can promote/demote a role afterward (enforced by RLS).
model Profile {
  id        String   @id @db.Uuid
  name      String?
  phone     String?
  role      Role     @default(staff)
  createdAt DateTime @default(now()) @map("created_at")

  stockMovements   StockMovement[]
  payments         Payment[]
  receipts         Receipt[]
  quotations       Quotation[]
  deliveryChallans DeliveryChallan[]

  @@map("profiles")
}

model Customer {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  address       String?
  phone         String?
  ledgerBalance Decimal  @default(0) @map("ledger_balance") @db.Decimal(12, 2)
  // Soft-delete flag. "Remove" in the UI sets this false rather than hard
  // deleting — payments have an ON DELETE RESTRICT FK to protect the audit
  // trail, so any customer with payment history (i.e. almost all of them)
  // could never be hard-deleted. Archiving keeps removal instant either way.
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  payments         Payment[]
  receipts         Receipt[]
  quotations       Quotation[]
  deliveryChallans DeliveryChallan[]

  @@map("customers")
}

model Supplier {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  address       String?
  phone         String?
  ledgerBalance Decimal  @default(0) @map("ledger_balance") @db.Decimal(12, 2)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  payments Payment[]

  @@map("suppliers")
}

// The atomic ledger-affecting event. Always reduces the target's
// ledgerBalance by `amount` (customer paying us down, or us paying a
// supplier down) — exactly one of customerId/supplierId is set, enforced
// by a CHECK constraint in the migration. Append-only, like stock_movements:
// no update/delete policy, since ledger disputes get settled by the record
// trail, not by editing history.
model Payment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId  String?  @map("customer_id") @db.Uuid
  supplierId  String?  @map("supplier_id") @db.Uuid
  amount      Decimal  @db.Decimal(12, 2)
  method      String?
  note        String?
  // Set when this payment was generated as the "Advance" portion of a
  // Receipt/Invoice, rather than recorded standalone via the Ledger dialog.
  referenceType String? @map("reference_type")
  referenceId   String? @map("reference_id") @db.Uuid
  paymentDate DateTime @default(now()) @map("payment_date")
  createdBy   String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  customer Customer? @relation(fields: [customerId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  creator  Profile?  @relation(fields: [createdBy], references: [id])

  @@map("payments")
}

// The financial-close document — matches the paper invoice book exactly:
// invoiceNo continues the physical book's sequence (last paper invoice was
// 1907; a Postgres sequence started at 1908 guarantees atomic, gapless-per-
// transaction numbering). previousBalance/total/balance are snapshotted at
// creation time rather than computed live, since the paper document itself
// is a permanent record — it must keep showing the numbers as they were on
// the day it was issued even if the customer's balance moves afterward.
model Receipt {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNo       Int      @unique @default(dbgenerated("nextval('invoice_no_seq')")) @map("invoice_no")
  customerId      String   @map("customer_id") @db.Uuid
  date            DateTime @default(now())
  previousBalance Decimal  @map("previous_balance") @db.Decimal(12, 2)
  itemsTotal      Decimal  @map("items_total") @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  advance         Decimal  @default(0) @db.Decimal(12, 2)
  balance         Decimal  @db.Decimal(12, 2)
  termsSnapshot   String?  @map("terms_snapshot")
  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  customer Customer      @relation(fields: [customerId], references: [id])
  creator  Profile?      @relation(fields: [createdBy], references: [id])
  items    ReceiptItem[]

  @@map("receipts")
}

model ReceiptItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receiptId   String  @map("receipt_id") @db.Uuid
  description String
  size        String?
  qty         Decimal @db.Decimal(12, 2)
  sqft        Decimal @db.Decimal(12, 2)
  ratePerSqft Decimal @map("rate_per_sqft") @db.Decimal(12, 2)
  amount      Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  receipt Receipt @relation(fields: [receiptId], references: [id])

  @@map("receipt_items")
}

// Optional, informal pre-sale document (per plan Section 6, often skipped
// for walk-in stock sales) — never touches the ledger, unlike Receipt.
// quotationNo uses its own numbering series (QT-0001...), independent of
// the invoice sequence. Unlike Receipt, items and status are editable
// after creation (owner/staff can revise a quotation before it's acted
// on), since nothing financial has been committed yet.
model Quotation {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotationNo   String          @unique @default(dbgenerated("'QT-' || lpad(nextval('quotation_no_seq')::text, 4, '0')")) @map("quotation_no")
  customerId    String          @map("customer_id") @db.Uuid
  date          DateTime        @default(now())
  status        QuotationStatus @default(draft)
  itemsTotal    Decimal         @map("items_total") @db.Decimal(12, 2)
  termsSnapshot String?         @map("terms_snapshot")
  createdBy     String?         @map("created_by") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  customer         Customer          @relation(fields: [customerId], references: [id])
  creator          Profile?          @relation(fields: [createdBy], references: [id])
  items            QuotationItem[]
  deliveryChallans DeliveryChallan[]

  @@map("quotations")
}

model QuotationItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotationId String  @map("quotation_id") @db.Uuid
  description String
  size        String?
  qty         Decimal @db.Decimal(12, 2)
  sqft        Decimal @db.Decimal(12, 2)
  ratePerSqft Decimal @map("rate_per_sqft") @db.Decimal(12, 2)
  amount      Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

// Goods-leave-the-yard document (per plan Section 5: "vehicle/driver info,
// status: draft/dispatched/delivered"). Like Quotation, never touches the
// ledger, so stays fully editable, and its own DC-0001 numbering series is
// independent of both invoice_no_seq and quotation_no_seq. quotationId is
// an optional back-reference for when a challan originated from a
// quotation — SET NULL on delete so removing a quotation doesn't break the
// delivery record. The signature line matters most here of all three
// document types (per Section 3.3: "especially relevant for the Delivery
// Challan") since it's the physical goods-received sign-off.
model DeliveryChallan {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  challanNo     String        @unique @default(dbgenerated("'DC-' || lpad(nextval('challan_no_seq')::text, 4, '0')")) @map("challan_no")
  customerId    String        @map("customer_id") @db.Uuid
  quotationId   String?       @map("quotation_id") @db.Uuid
  date          DateTime      @default(now())
  status        ChallanStatus @default(draft)
  vehicleNumber String?       @map("vehicle_number")
  driverName    String?       @map("driver_name")
  itemsTotal    Decimal       @map("items_total") @db.Decimal(12, 2)
  termsSnapshot String?       @map("terms_snapshot")
  createdBy     String?       @map("created_by") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  customer  Customer              @relation(fields: [customerId], references: [id])
  quotation Quotation?            @relation(fields: [quotationId], references: [id])
  creator   Profile?              @relation(fields: [createdBy], references: [id])
  items     DeliveryChallanItem[]

  @@map("delivery_challans")
}

model DeliveryChallanItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  challanId   String  @map("challan_id") @db.Uuid
  description String
  size        String?
  qty         Decimal @db.Decimal(12, 2)
  sqft        Decimal @db.Decimal(12, 2)
  ratePerSqft Decimal @map("rate_per_sqft") @db.Decimal(12, 2)
  amount      Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  challan DeliveryChallan @relation(fields: [challanId], references: [id], onDelete: Cascade)

  @@map("delivery_challan_items")
}

model InventoryItem {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category          String
  subCategory       String?  @map("sub_category")
  description       String
  size              String?
  unit              ItemUnit @default(sqft)
  defaultRatePerSqft Decimal? @map("default_rate_per_sqft") @db.Decimal(12, 2)
  qtyOnHand         Decimal  @default(0) @map("qty_on_hand") @db.Decimal(12, 2)
  // Null means "not tracked for low-stock alerts" — a single global
  // threshold would be meaningless across item types this different (a
  // big slab vs. a box of patti strips), so this is per-item and optional.
  reorderLevel      Decimal? @map("reorder_level") @db.Decimal(12, 2)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  stockMovements StockMovement[]

  @@map("inventory_items")
}

// Append-only stock ledger. reference_id intentionally has no FK constraint —
// it will point at purchases/receipts/adjustments rows once those tables
// exist (build order steps 3-4); reference_type disambiguates the source.
model StockMovement {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId        String         @map("item_id") @db.Uuid
  direction     StockDirection
  qty           Decimal        @db.Decimal(12, 2)
  referenceType String?        @map("reference_type")
  referenceId   String?        @map("reference_id") @db.Uuid
  note          String?
  createdBy     String?        @map("created_by") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at")

  item    InventoryItem @relation(fields: [itemId], references: [id])
  creator Profile?      @relation(fields: [createdBy], references: [id])

  @@map("stock_movements")
}
